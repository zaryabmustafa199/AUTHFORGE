# ============================================================
# AuthForge — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control (it contains secrets).
# ============================================================

# ── Application ──
APP_NAME=AuthForge
SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=INFO

# ── Database ──
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Use "db" as host when running inside Docker, "localhost" when running outside
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/authforge

# ── Redis ──
# Use "redis" as host when running inside Docker, "localhost" when running outside
REDIS_URL=redis://localhost:6380/0

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ── Email ──
# Development: Use MailHog (no auth, no TLS)
# Production: Use your SMTP provider (SendGrid, AWS SES, Gmail, etc.)
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@authforge.dev
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=

# ── OAuth (Phase 7) ──
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/v1/auth/oauth/google/callback

# ── Security ──
RATE_LIMIT_LOGIN=5
RATE_LIMIT_SIGNUP=3
RATE_LIMIT_WINDOW_SECONDS=60
ALLOWED_ORIGINS=["http://localhost:3000"]
